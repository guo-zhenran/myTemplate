% myPresentation.sty
% Custom Beamer theme – cleaned and enhanced
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{myPresentation}[2024/01/01 Custom Beamer Theme]

% ================ Required packages ================
\usepackage{etoolbox}          % for \ifdefempty
\usepackage{pgfkeys}           % key-value for thankyou page
\usepackage{xcolor}            % color definitions
\usepackage{array, multirow, nicematrix, listings, tikz}
\usetikzlibrary{matrix, positioning}

% ================ Fonts (LuaLaTeX / XeLaTeX) ================
\usepackage{fontspec}
\setmainfont{Optima Regular}[
    UprightFont    = *,
    BoldFont       = Optima Bold,
    ItalicFont     = Optima Italic,
    BoldItalicFont = Optima Bold Italic,
]

\usepackage{unicode-math}
\setmathfont{ArsenalMath-Sans.otf}

% ================ Beamer mode & base settings ================
\mode<presentation>
\setbeameroption{show notes on second screen=right}
\usetheme{boxes}
\usecolortheme{default}
\usefonttheme{serif}
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}[numbered]

% ================ Color palette ================
\definecolor{primary}{HTML}{08457E}
\definecolor{secondary}{HTML}{B02A30}
\definecolor{tertiary}{HTML}{006400}
\definecolor{alert}{HTML}{B22222}
\definecolor{example}{HTML}{008B8B}
\definecolor{lightblue}{HTML}{E6F0FA}
\definecolor{lightgray}{HTML}{F5F5F5}
\definecolor{mediumgray}{HTML}{808080}
\definecolor{darkgray}{HTML}{424242}

% ================ Apply colors ================
\setbeamercolor{structure}{fg=primary}
\setbeamercolor{normal text}{fg=darkgray}
\setbeamercolor{alerted text}{fg=alert}
\setbeamercolor{example text}{fg=example}
\setbeamercolor{title}{fg=primary}
\setbeamercolor{frametitle}{fg=primary}
\setbeamercolor{framesubtitle}{fg=mediumgray}
\setbeamercolor{title in head/foot}{fg=primary}
\setbeamercolor{author in head/foot}{fg=mediumgray}
\setbeamercolor{date in head/foot}{fg=mediumgray}
\setbeamercolor{block title}{bg=lightblue, fg=primary}
\setbeamercolor{block body}{bg=lightblue!30}
\setbeamercolor{block title example}{bg=lightgray, fg=example}
\setbeamercolor{block body example}{bg=lightgray!30}
\setbeamercolor{block title alerted}{bg=lightblue!50!red!10, fg=alert}
\setbeamercolor{block body alerted}{bg=lightblue!50!red!5}
\setbeamercolor{item}{fg=primary}
\setbeamercolor{subitem}{fg=primary}
\setbeamercolor{subsubitem}{fg=primary}
\setbeamercolor{enumerate item}{fg=primary}
\setbeamercolor{enumerate subitem}{fg=primary}
\setbeamercolor{enumerate subsubitem}{fg=primary}
\setbeamercolor{description item}{fg=primary}
\setbeamercolor{section in head/foot}{fg=primary}
\setbeamercolor{subsection in head/foot}{fg=mediumgray}
\setbeamercolor{footline}{fg=mediumgray}

% ================ Font settings ================
\setbeamerfont{title}{size=\Large, family=\rmfamily, series=\bfseries}
\setbeamerfont{frametitle}{size=\large, family=\rmfamily}
\setbeamerfont{framesubtitle}{size=\small, family=\rmfamily}
\setbeamerfont{block title}{family=\rmfamily}
\setbeamerfont{block title example}{family=\rmfamily}
\setbeamerfont{block title alerted}{family=\rmfamily}
\setbeamerfont{caption name}{family=\rmfamily}

% ================ Math shortcuts ================
\newcommand{\mat}[1]{\mathbf{#1}}
\newcommand{\vct}[1]{\boldsymbol{#1}}
\newcommand{\E}{\mathbb{E}}
\newcommand{\Prob}{\mathbb{P}}
\newcommand{\Var}{\operatorname{Var}}
\newcommand{\Cov}{\operatorname{Cov}}
\newcommand{\tp}{^{\prime}}
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\C}{\mathbb{C}}

% ================ Theorem environments ================
\makeatletter
\@ifundefined{theorem}{%
  \theoremstyle{plain}
  \newtheorem{theorem}{Theorem}[section]
}{}
\@ifundefined{proposition}{%
  \theoremstyle{plain}
  \newtheorem{proposition}[theorem]{Proposition}
}{}
\@ifundefined{conjecture}{%
  \theoremstyle{plain}
  \newtheorem{conjecture}[theorem]{Conjecture}
}{}
\@ifundefined{axiom}{%
  \theoremstyle{plain}
  \newtheorem{axiom}[theorem]{Axiom}
}{}
\@ifundefined{definition}{%
  \theoremstyle{definition}
  \newtheorem{definition}{Definition}[section]
}{}
\@ifundefined{example}{%
  \theoremstyle{definition}
  \newtheorem{example}{Example}[section]
}{}
\@ifundefined{exercise}{%
  \theoremstyle{definition}
  \newtheorem{exercise}{Exercise}[section]
}{}
\@ifundefined{assumption}{%
  \theoremstyle{definition}
  \newtheorem{assumption}{Assumption}[section]
}{}
\@ifundefined{remark}{%
  \theoremstyle{remark}
  \newtheorem*{remark}{Remark}
}{}
\@ifundefined{note}{%
  \theoremstyle{remark}
  \newtheorem*{note}{Note}
}{}
\makeatother

% ================ Custom proof environment ================
\renewenvironment{proof}[1][\proofname]{%
  \par\vspace{0.5em}
  \noindent\textbf{#1:}\quad\itshape
}{%
  \hfill$\square$\par\vspace{0.5em}
}
\providecommand{\proofname}{Proof}

% ================ Block styling ================
\setbeamertemplate{blocks}[rounded][shadow=true]
\addtobeamertemplate{block begin}{\vspace*{2mm}}{}
\addtobeamertemplate{block end}{\vspace*{2mm}}{}

% ================ List styling ================
\setbeamertemplate{itemize items}[circle]
\setbeamertemplate{itemize subitem}[circle]
\setbeamertemplate{itemize subsubitem}[circle]

% ================ Footline ================
\setbeamertemplate{footline}{%
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,left]{title in head/foot}%
      \hspace*{2em}\usebeamerfont{title in head/foot}\insertshorttitle
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,center]{date in head/foot}%
      \usebeamerfont{date in head/foot}\insertsection%
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,right]{date in head/foot}%
      \insertframenumber{} / \inserttotalframenumber \hspace*{2em}
    \end{beamercolorbox}%
  }%
  \vskip0pt%
}

% ================ Caption style ================
\setbeamertemplate{caption label separator}{: }
\setbeamerfont{caption}{size=\footnotesize}

% ================ Section page ================
\defbeamertemplate*{section page}{custom}[1][]{%
  \begingroup
    \centering
    \vspace*{\fill}
    {\color{darkgray}\usebeamerfont{section in toc}
     \fontsize{14}{10}\selectfont\sffamily
     SECTION \insertsectionnumber\par}
    \vspace*{0.5cm}
    {\color{primary}\usebeamerfont{frametitle}
     \fontsize{16}{10}\selectfont\bfseries\sffamily
     \insertsectionhead\par}
    \vspace*{\fill}
  \endgroup
}
\AtBeginSection[]{%
  \begin{frame}[plain,noframenumbering]
    \usebeamertemplate{section page}
  \end{frame}
}

% ================ Table of contents ================
\setbeamertemplate{section in toc}[square]
\setbeamertemplate{subsection in toc}[square]
\setbeamerfont{section in toc}{size=\normalsize, family=\sffamily}
\setbeamerfont{subsection in toc}{size=\small, family=\sffamily}
\setbeamercolor{section in toc}{fg=darkgray}
\setbeamercolor{subsection in toc}{fg=darkgray!80}

% ================ Margins ================
\setbeamersize{text margin left=10mm, text margin right=10mm}

% ================ Custom box environments ================
\newenvironment{infobox}[1]{%
  \begin{block}{#1}\small
}{%
  \end{block}
}
\newenvironment{alertbox}[1]{%
  \begin{alertblock}{#1}\small
}{%
  \end{alertblock}
}
\newenvironment{examplebox}[1]{%
  \begin{exampleblock}{#1}\small
}{%
  \end{exampleblock}
}

% ================ Emphasized text ================
\newcommand{\emphblue}[1]{\textcolor{primary}{\sffamily\bfseries #1}}
\newcommand{\emphred}[1]{\textcolor{alert}{\sffamily\bfseries #1}}
\newcommand{\emphgreen}[1]{\textcolor{example}{\sffamily\bfseries #1}}

% ================ Thank you page (key‑value) ================
\pgfkeys{
  /thankyou/.is family, /thankyou,
  default/.style = {
    email    = \href{mailto:guo.zhenran@stu.sufe.edu.cn}{guo.zhenran@stu.sufe.edu.cn},
    homepage = \href{http://guo-zhenran.github.io}{guo-zhenran.github.io},
    source   = \href{https://github.com/guo-zhenran}{github.com/guo-zhenran},
    takeaway = Hope you bring home some joy and food for thought!
  },
  email/.store in    = \thankyouemail,
  homepage/.store in = \thankyouhomepage,
  source/.store in   = \thankyousource,
  takeaway/.store in = \thankyoutakeaway,
}
\pgfkeys{/thankyou, default}

\newcommand{\makethankyoupage}[1][]{%
  % Save original values
  \let\origthankyouemail\thankyouemail
  \let\origthankyouhomepage\thankyouhomepage
  \let\origthankyousource\thankyousource
  \let\origthankyoutakeaway\thankyoutakeaway
  
  % Apply user-provided parameters
  \pgfkeys{/thankyou, #1}
  
  \begin{frame}
    \begin{center}
      \vspace{1cm}
      {\Huge \textcolor{primary}{Thank You!}}
      
      \vspace{0.5cm}
      {\Large Questions?}
      
      \vspace{0.5cm}
      \begin{tabular}{cc}
        \textbf{Key Takeaway:} & \parbox{0.7\textwidth}{\thankyoutakeaway}
      \end{tabular}

% Create information table
      \ifdefempty{\thankyouemail}{}{%
        \vspace{0.5cm}
        \begin{tabular}{@{}ll@{}}
          \ifdefempty{\thankyouemail}{}{%
            \textcolor{alert}{Email:} & \thankyouemail \\
          }
          \ifdefempty{\thankyouhomepage}{}{%
            \textcolor{alert}{Homepage:} & \thankyouhomepage \\
          }
          \ifdefempty{\thankyousource}{}{%
            \textcolor{alert}{Source:} & \thankyousource \\
          }
        \end{tabular}
      }
    \end{center}
  \end{frame}
  
  % Restore original values
  \renewcommand{\thankyouemail}{\origthankyouemail}
  \renewcommand{\thankyouhomepage}{\origthankyouhomepage}
  \renewcommand{\thankyousource}{\origthankyousource}
  \renewcommand{\thankyoutakeaway}{\origthankyoutakeaway}
}

% ================ Frame title spacing ================
\addtobeamertemplate{frametitle}{\vspace*{0.5cm}}{\vspace*{0.2cm}}

% ================ Bibliography ================
\setbeamertemplate{bibliography item}[text]
\setbeamerfont{bibliography entry author}{size=\small, family=\sffamily}
\setbeamerfont{bibliography entry title}{size=\small, family=\sffamily}
\setbeamerfont{bibliography entry location}{size=\small, family=\sffamily}
\setbeamerfont{bibliography entry note}{size=\small, family=\sffamily}
\setbeamercolor{bibliography entry author}{fg=primary}
\setbeamercolor{bibliography entry title}{fg=darkgray}
\setbeamercolor{bibliography entry location}{fg=mediumgray}
\setbeamercolor{bibliography entry note}{fg=mediumgray}

% ================ Convenience environment for long frames ================
\newenvironment{longframe}[1][allowframebreaks]{%
  \begin{frame}[#1]%
}{%
  \end{frame}%
}

\mode<all>
